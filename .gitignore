# ==============================================================================
#  SECRETS — never commit these
# ==============================================================================
cookies.txt
cookies*.txt
*.cookies
.env
.env.*
!.env.example      # template (no real secrets) — safe to commit

# ==============================================================================
#  TRANSIENT / GENERATED
# ==============================================================================
_yt_temp/          # temp audio yt-dlp writes during Whisper transcription
*.part             # yt-dlp partial downloads
*.ytdl

# ==============================================================================
#  PYTHON
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/

# ==============================================================================
#  OS / EDITOR
# ==============================================================================
Thumbs.db
desktop.ini
.DS_Store
.idea/
.vscode/*
!.vscode/settings.json

# ==============================================================================
#  DATA / GENERATED — regenerable or large; not versioned (code & text only)
# ==============================================================================
chroma_db/
outputs/
vector_visualisation.html

# ==============================================================================
#  LARGE / COPYRIGHTED MEDIA — source binaries, kept out of the repo
#  (the .txt transcripts, prompts, and urls.txt ARE tracked)
# ==============================================================================
*.pdf
*.webm
*.mp3
*.m4a
*.wav
